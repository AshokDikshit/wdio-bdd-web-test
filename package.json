{
  "name": "playwright-bdd-web-test",
  "version": "1.0.0",
  "description": "Playwright BDD Test Automation Framework - Migrated from WebDriverIO",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui",
    "test:chromium": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:webkit": "playwright test --project=webkit",
    "test:mobile": "playwright test --project='Mobile Chrome'",
    "test:headless": "playwright test --config=playwright-headless.config.ts",
    "test:parallel": "playwright test --workers=4",
    "test:serial": "playwright test --workers=1",
    "test:smoke": "playwright test --grep='@smoke'",
    "test:regression": "playwright test --grep='@regression'",
    "bdd:generate": "echo 'BDD generation currently disabled due to compatibility issues'",
    "bdd:test": "echo 'BDD tests currently disabled - use npm run test instead'",
    "cucumber:test": "echo 'Cucumber tests migrated to Playwright BDD'",
    "cucumber:dry-run": "echo 'Use playwright test --list instead'",
    "cucumber:format": "echo 'Reports generated automatically by Playwright'",
    "reports": "node ./tests/support/generate-cucumber-report.js",
    "reports:open": "open reports/index.html",
    "install:browsers": "playwright install",
    "install:deps": "playwright install-deps",
    "setup": "npm run install:browsers && npm run install:deps",
    "clean": "rm -rf test-results test-results-headless reports screenshots .features-gen",
    "lint": "eslint tests/**/*.ts",
    "lint:fix": "eslint tests/**/*.ts --fix",
    "type-check": "tsc --noEmit",
    "pretest": "npm run type-check",
    "posttest": "npm run reports",
    "ci": "npm run clean && npm run type-check && npm run test:headless",
    "dev": "npm run test:headed"
  },
  "keywords": [
    "playwright",
    "bdd",
    "cucumber",
    "typescript",
    "automation",
    "testing",
    "e2e"
  ],
  "author": "Your Name",
  "license": "MIT",
  "devDependencies": {
    "@cucumber/cucumber": "^10.0.0",
    "@cucumber/pretty-formatter": "^1.0.0",
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.50.0",
    "pirates": "^4.0.7",
    "playwright-bdd": "^8.5.1",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@types/js-yaml": "^4.0.9",
    "js-yaml": "^4.1.1",
    "multiple-cucumber-html-reporter": "^3.10.0"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "your-repository-url"
  },
  "bugs": {
    "url": "your-repository-url/issues"
  },
  "homepage": "your-repository-url#readme"
}
